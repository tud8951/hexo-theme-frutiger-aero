<div class="projects-container">
  <header class="projects-header">
    <h1><%= __('projects.title') %></h1>
    <p><%= __('projects.subtitle') %></p>
  </header>

  <div class="projects-list" id="projects-list">
    <div class="loading-status"><%= __('projects.loading') %></div>
  </div>
</div>

<script>
  const MANUAL_PROJECTS = <%- JSON.stringify(theme.projects || []) %>;
  const GITHUB_USERNAME = '<%= theme.github ? theme.github.username : '' %>';
  const GITHUB_REPOS = <%- JSON.stringify(theme.github ? theme.github.repos || [] : []) %>;
  const TRANSLATIONS = {
    error_fetch: '<%= __('projects.error_fetch') %>',
    stars: '<%= __('projects.stars') %>',
    forks: '<%= __('projects.forks') %>',
    updated: '<%= __('projects.updated') %>'
  };

  // 如果有手动配置的项目，直接使用
  if (MANUAL_PROJECTS && MANUAL_PROJECTS.length > 0) {
    renderManualProjects(MANUAL_PROJECTS);
  } else if (GITHUB_USERNAME && GITHUB_USERNAME !== 'your_github_username' && GITHUB_USERNAME !== '') {
    fetchGitHubData(GITHUB_USERNAME, GITHUB_REPOS);
  } else {
    document.getElementById('projects-list').innerHTML = `<div class="error-status">Please configure projects in theme config</div>`;
  }

  async function fetchGitHubData(username, customRepos) {
    try {
      console.log('Fetching GitHub data for:', username);
      console.log('Custom repos:', customRepos);
      
      let repos = [];
      let errorMsg = '';
      
      if (customRepos && customRepos.length > 0) {
        const repoPromises = customRepos.map(repo => 
          fetch(`https://api.github.com/repos/${username}/${repo}`, {
            headers: { 'Accept': 'application/vnd.github.v3+json' }
          }).then(res => {
            console.log(`Response for ${repo}:`, res.status);
            if (!res.ok) {
              console.error(`Failed to fetch ${repo}:`, res.status);
              return null;
            }
            return res.json();
          })
        );
        repos = (await Promise.all(repoPromises)).filter(repo => repo !== null);
        console.log('Fetched repos:', repos);
      } else {
        const response = await fetch(`https://api.github.com/users/${username}/repos?sort=updated&per_page=30`, {
          headers: { 'Accept': 'application/vnd.github.v3+json' }
        });
        console.log('User repos response:', response.status);
        
        if (!response.ok) {
          errorMsg = `HTTP ${response.status}: ${response.statusText}`;
          throw new Error(errorMsg);
        }
        
        repos = await response.json();
        console.log('User repos:', repos);
      }
      
      if (repos && repos.length > 0) {
        const filteredRepos = repos.filter(repo => repo && !repo.fork);
        console.log('Filtered repos:', filteredRepos);
        renderProjects(filteredRepos);
      } else {
        document.getElementById('projects-list').innerHTML = `<div class="error-status">No projects found. Check console for details.</div>`;
      }
    } catch (error) {
      console.error('Fetch error:', error);
      document.getElementById('projects-list').innerHTML = `<div class="error-status">Error: ${error.message || TRANSLATIONS.error_fetch}</div>`;
    }
  }

  function renderProjects(repos) {
    const list = document.getElementById('projects-list');
    list.innerHTML = '';
    
    repos.forEach(repo => {
      // 检查必要属性是否存在
      if (!repo || !repo.name || !repo.html_url) {
        return;
      }
      
      const card = document.createElement('a');
      card.href = repo.html_url;
      card.target = '_blank';
      card.className = 'project-card';
      
      const updatedDate = repo.updated_at ? new Date(repo.updated_at) : new Date();
      const formattedDate = updatedDate.toLocaleDateString();
      
      const languageColors = {
        JavaScript: '#f1e05a',
        TypeScript: '#2b7489',
        Python: '#3572A5',
        Java: '#b07219',
        'C++': '#f34b7d',
        C: '#555555',
        Go: '#00ADD8',
        Rust: '#dea584',
        Ruby: '#701516',
        PHP: '#4F5D95',
        Swift: '#ffac45',
        Kotlin: '#F18E33',
        HTML: '#e34c26',
        CSS: '#563d7c',
        Vue: '#41b883',
        React: '#61dafb'
      };
      
      const langColor = languageColors[repo.language] || '#8b949e';
      
      card.innerHTML = `
